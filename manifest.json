// Tu imagen del fileteado en Base64
  const iconUrl = 'data:image/png;base64,...'; // (Dejá todo el código largo que ya tenías acá adentro)

  // NUEVO MANIFIESTO
  const manifest = {
    "name": "Fundida App",
    "short_name": "Fundida",
    "start_url": "./index.html",
    "display": "standalone",
    "background_color": "#111625",
    "theme_color": "#6C63FF",
    "icons": [
      {
        "src": iconUrl,
        "sizes": "512x512",
        "type": "image/png",
        "purpose": "any maskable"
      }
    ]
  };

  // Esto inyecta el manifiesto de forma segura sin servidores
  const manifestBlob = new Blob([JSON.stringify(manifest)], {type: 'application/json'});
  document.getElementById('manifestLink').href = URL.createObjectURL(manifestBlob);
})();
